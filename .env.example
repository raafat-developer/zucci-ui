# Zucci Admin — Environment Variables
#
# Three environments (Vite --mode):
#   local/dev  → .env.development  → https://api.zucci.xyz  (same as staging)
#   staging    → .env.staging      → https://api.zucci.xyz
#   production → .env.production   → https://api.zucci.com
#
# Copy this file to .env.local to override any value locally (gitignored).

VITE_APP_ENV=local
VITE_API_BASE=https://api.zucci.xyz/api/v1/

# Offline mock API (optional)
# VITE_USE_MOCK=true
